{
  "mcpServers": {
    "filesystem": {
      "command": "node",
      "args": ["mcp-npm/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js", "${USER_HOME}"],
      "_comment": "文件系统访问，默认允许访问用户主目录"
    },
    "fetch": {
      "command": "node",
      "args": ["mcp-npm/node_modules/@kazuph/mcp-fetch/dist/index.js"]
    }
  }
}
