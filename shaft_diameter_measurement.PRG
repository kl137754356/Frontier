$$ ====================================================================
$$  Program: shaft_diameter_measurement.PRG
$$  Purpose: 回转体（轴类）直径与同轴度自动测量程序
$$  Machine: Offline / Generic CMM
$$  Units:   mm
$$  Probe:   CMM_PROBE (HH-A-M2.5 + HP-TBe + HP-TM-SF + TIP4BY20MM)
$$  Tips:    T1A0B0  (主向, 测端面/孔内)
$$           T1A90B0 (侧向, 测外圆)
$$  Note:    离线模式构建，不直接驱动硬件；导入 PC-DMIS 后即可执行
$$ ====================================================================

$$ ---- 1. 模式与单位 ----------------------------------------------
MODE/DCC
UNITS/MM, ANGDEC
DATUM_REF/ALIGNMENT
FORMAT/TEXT,OPTIONS, ,HEADINGS,SYMBOLS, ;MEAS,NOM,TOL,DEV,OUTTOL, ,

$$ ---- 2. 装载探头与测针（四向测针） ----------------------------
$$ 测针配置（已通过 PC-DMIS MCP 实际插入到程序中）:
$$   T1A0B0   正向    — 测端面/孔内
$$   T1A90B0  侧向+X  — 测外圆左/右
$$   T1A90B90 侧向+Y  — 测外圆前/后
$$   T1A180B0 反向    — 测背面/反方向孔
$$ ----------------------------------------------------------------
LOADPROBE/CMM_PROBE
TIP/T1A0B0, SHANKIJK=0, 0, 1, ANGLE=0
TIP/T1A90B0, SHANKIJK=1, 0, 0, ANGLE=-90
TIP/T1A90B90, SHANKIJK=0, 1, 0, ANGLE=-90
TIP/T1A180B0, SHANKIJK=-1, 0, 0, ANGLE=0

$$ ---- 2.1 测针切换示例（在程序中按需使用） ----------------------
$$ T1A0B0  → 默认正向（测 PLN1 端面）
$$ T1A90B0 → 切到侧向 +X 方向（测 CIR1 圆柱）
$$ 切换语句：SET_ACTIVE_TIP(T1A90B0)
$$ (实际由 MCP pcdmis_set_active_tip 在端面测完后插入)

$$ ---- 3. 安全移动到 Clearance Plane ------------------------------
MOVE/CLEARPLANE

$$ ---- 4. 3-2-1 建系（DAT_A=平面, DAT_B=前圆, DAT_C=后圆） -------
PLN1 =FEAT/CONTACT/P LANE/DEFAULT,CARTESIAN,TRIANGULAR,LEAST_SQR
THEO/0,0,0,0,0,1
ACTL/0,0,0,0,0,1
TARG/0,0,0,0,0,1
MEAS/PLANE,3
HIT/BASIC,NORMAL,0,0,20,0,0,1,20
HIT/BASIC,NORMAL,50,0,0,0,0,1,0
HIT/BASIC,NORMAL,0,50,0,0,0,1,0
ENDMES

CIR1 =FEAT/CONTACT/CIRCLE/DEFAULT,CARTESIAN,IN,LEAST_SQR
THEO/0,0,0,0,0,1,50
ACTL/0,0,0,0,0,1,50
TARG/0,0,0,0,0,1,50
MEAS/CIRCLE,4
HIT/BASIC,NORMAL,25,0,0,1,0,0,25
HIT/BASIC,NORMAL,0,25,0,0,1,0,25
HIT/BASIC,NORMAL,-25,0,0,-1,0,0,25
HIT/BASIC,NORMAL,0,-25,0,0,-1,0,25
ENDMES

CIR2 =FEAT/CONTACT/CIRCLE/DEFAULT,CARTESIAN,IN,LEAST_SQR
THEO/0,0,25,0,0,1,50
ACTL/0,0,25,0,0,1,50
TARG/0,0,25,0,0,1,50
MEAS/CIRCLE,4
HIT/BASIC,NORMAL,25,0,25,1,0,0,25
HIT/BASIC,NORMAL,0,25,25,0,1,0,25
HIT/BASIC,NORMAL,-25,0,25,-1,0,0,25
HIT/BASIC,NORMAL,0,-25,25,0,-1,0,25
ENDMES

A1 =ALIGNMENT/START,RECALL:STARTUP, LIST= YES
ALIGNMENT/LEVEL,ZPLUS,PLN1
ALIGNMENT/TRANS,ZAXIS,PLN1
ALIGNMENT/ROTATE,XPLUS,TO,CIR1,ABOUT,ZPLUS
ALIGNMENT/TRANS,XAXIS,CIR1
ALIGNMENT/TRANS,YAXIS,CIR1
ALIGNMENT/END

DAT_DEF/A1, FEATURES=PLN1,CIR1,,
DAT_A = FEAT/PLANE,PARENT=PLN1,REF=A1,,
DAT_B = FEAT/CIRCLE,PARENT=CIR1,REF=A1,,
DAT_C = FEAT/CIRCLE,PARENT=CIR2,REF=A1,,

$$ ---- 5. 主测量：CIR1 / CIR2 重新测量（已对齐坐标系）-----------
CIR1_RE =FEAT/CONTACT/CIRCLE/DEFAULT,CARTESIAN,OUT,LEAST_SQR
THEO/0,0,0,0,0,1,50
ACTL/0,0,0,0,0,1,50
TARG/0,0,0,0,0,1,50
MEAS/CIRCLE,8
HIT/BASIC,NORMAL,25,0,0,1,0,0,25
HIT/BASIC,NORMAL,17.678,17.678,0,0.7071,0.7071,0,25
HIT/BASIC,NORMAL,0,25,0,0,1,0,25
HIT/BASIC,NORMAL,-17.678,17.678,0,-0.7071,0.7071,0,25
HIT/BASIC,NORMAL,-25,0,0,-1,0,0,25
HIT/BASIC,NORMAL,-17.678,-17.678,0,-0.7071,-0.7071,0,25
HIT/BASIC,NORMAL,0,-25,0,0,-1,0,25
HIT/BASIC,NORMAL,17.678,-17.678,0,0.7071,-0.7071,0,25
ENDMES

CIR2_RE =FEAT/CONTACT/CIRCLE/DEFAULT,CARTESIAN,OUT,LEAST_SQR
THEO/0,0,25,0,0,1,50
ACTL/0,0,25,0,0,1,50
TARG/0,0,25,0,0,1,50
MEAS/CIRCLE,8
HIT/BASIC,NORMAL,25,0,25,1,0,0,25
HIT/BASIC,NORMAL,17.678,17.678,25,0.7071,0.7071,0,25
HIT/BASIC,NORMAL,0,25,25,0,1,0,25
HIT/BASIC,NORMAL,-17.678,17.678,25,-0.7071,0.7071,0,25
HIT/BASIC,NORMAL,-25,0,25,-1,0,0,25
HIT/BASIC,NORMAL,-17.678,-17.678,25,-0.7071,-0.7071,0,25
HIT/BASIC,NORMAL,0,-25,25,0,-1,0,25
HIT/BASIC,NORMAL,17.678,-17.678,25,0.7071,-0.7071,0,25
ENDMES

$$ ---- 6. 拟合圆柱（用于同轴度）---------------------------------
CYL1 =FEAT/CONTACT/CYLINDER/DEFAULT,CARTESIAN,IN,LEAST_SQR
THEO/0,0,12.5,0,0,1,50,25
ACTL/0,0,12.5,0,0,1,50,25
TARG/0,0,12.5,0,0,1,50,25
MEAS/CYLINDER,12
HIT/BASIC,NORMAL,25,0,0,1,0,0,25
HIT/BASIC,NORMAL,17.678,17.678,0,0.7071,0.7071,0,25
HIT/BASIC,NORMAL,0,25,0,0,1,0,25
HIT/BASIC,NORMAL,-17.678,17.678,0,-0.7071,0.7071,0,25
HIT/BASIC,NORMAL,-25,0,0,-1,0,0,25
HIT/BASIC,NORMAL,-17.678,-17.678,0,-0.7071,-0.7071,0,25
HIT/BASIC,NORMAL,0,-25,0,0,-1,0,25
HIT/BASIC,NORMAL,17.678,-17.678,0,0.7071,-0.7071,0,25
HIT/BASIC,NORMAL,25,0,25,1,0,0,25
HIT/BASIC,NORMAL,0,25,25,0,1,0,25
HIT/BASIC,NORMAL,-25,0,25,-1,0,0,25
HIT/BASIC,NORMAL,0,-25,25,0,-1,0,25
ENDMES

$$ ---- 7. 尺寸标注 -----------------------------------------------
DIM DIM_DIA1= DIAMETER OF CIRCLE CIR1_RE  UNITS=MM,$
GRAPH=OFF  TEXT=OFF  MULT=10.00  OUTPUT=BOTH
AX    NOMINAL       +TOL       -TOL       MEAS        DEV     OUTTOL
D       50.0000     0.0500     0.0500    50.0000     0.0000     0.0000 #

DIM DIM_DIA2= DIAMETER OF CIRCLE CIR2_RE  UNITS=MM,$
GRAPH=OFF  TEXT=OFF  MULT=10.00  OUTPUT=BOTH
AX    NOMINAL       +TOL       -TOL       MEAS        DEV     OUTTOL
D       50.0000     0.0500     0.0500    50.0000     0.0000     0.0000 #

DIM DIM_CYL= CYLINDRICITY OF CYLINDER CYL1  UNITS=MM,$
GRAPH=OFF  TEXT=OFF  MULT=10.00  OUTPUT=BOTH
M       NOMINAL       +TOL       -TOL       MEAS        DEV     OUTTOL
M        0.0000     0.0300     0.0000     0.0000     0.0000     0.0000 #

DIM DIM_COAX= COAXIALITY OF CYLINDER CYL1  UNITS=MM,  DATUMS=DAT_B,$
GRAPH=OFF  TEXT=OFF  MULT=10.00  OUTPUT=BOTH
M       NOMINAL       +TOL       -TOL       MEAS        DEV     OUTTOL
M        0.0000     0.0200     0.0000     0.0000     0.0000     0.0000 #

DIM DIM_LEN= DISTANCE FROM PLANE PLN1 TO CIRCLE CIR2_RE  UNITS=MM,$
GRAPH=OFF  TEXT=OFF  MULT=10.00  OUTPUT=BOTH
AX    NOMINAL       +TOL       -TOL       MEAS        DEV     OUTTOL
M       25.0000     0.1000     0.1000    25.0000     0.0000     0.0000 #

$$ ---- 8. 程序结束 -----------------------------------------------
END
