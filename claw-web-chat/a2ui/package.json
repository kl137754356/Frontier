{
  "name": "copilotkit-langgraph-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:ui": "next dev --turbopack",
    "dev:agent": "langgraphjs dev --config langgraph.json --port 8123 --no-browser",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@copilotkit/a2ui-renderer": "1.56.5",
    "@copilotkit/react-core": "1.56.5",
    "@copilotkit/runtime": "1.56.5",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.3",
    "@langchain/openai": "^1.4.7",
    "hono": "^4.12.10",
    "langchain": "^1.4.4",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@langchain/langgraph-cli": "^1.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
