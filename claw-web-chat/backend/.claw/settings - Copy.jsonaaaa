{
  "model": "deepseek-v4-flash",
  "mcpServers": {
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\AI_LLM\\LLM\\claw-code\\claw-code_network"
      ]
    },
    "web-search": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/claude-code-addon-web-search"
      ]
    },
    "pc-dmis": {
      "type": "stdio",
      "command": "node",
      "args": [
        "pc_dmis_mcp_server.mjs"
      ]
    }
  }
}
